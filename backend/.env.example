# File: .env.example
# Last Updated: 2026-04-27
# Role: 환경변수 템플릿 — 실제 값은 backend/.env (gitignored)에 작성
#
# 사용 방법
# 1) 이 파일을 backend/.env 로 복사
# 2) 본인 환경에 맞게 값 채우기 (특히 *_KEY 들)
# 3) .env 는 절대 git 에 커밋하지 말 것 (.gitignore 에서 제외 처리됨)

# ============================================================
# Supabase (pgvector)
# ============================================================
# Project URL: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://sffsnwnnixiaiujkzvbq.supabase.co

# service_role secret: Supabase Dashboard → Project Settings → API → service_role
# ⚠️ 절대 공개 X — placeholder 그대로 두고 본인 .env 에서만 실제 값 사용
SUPABASE_SERVICE_KEY=your_service_role_key_here

# pgvector 임베딩 저장 테이블 이름 (테이블 미생성 시 디폴트 유지)
SUPABASE_TABLE_NAME=documents

# pgvector 유사도 검색용 RPC 함수 이름 (함수 미생성 시 디폴트 유지)
SUPABASE_MATCH_RPC=match_documents

# ============================================================
# 임베딩 provider
# ============================================================
# openai | huggingface
EMBEDDING_PROVIDER=openai

# ============================================================
# OpenAI (EMBEDDING_PROVIDER=openai 일 때 필수)
# ============================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# HuggingFace (EMBEDDING_PROVIDER=huggingface 일 때 사용)
# ============================================================
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================
# HTTP / CORS
# ============================================================
# 쉼표로 구분. 프론트(Vite) 로컬 + 추후 배포 도메인 추가
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================
# RAG
# ============================================================
RAG_TOP_K=5
CHUNKS_JSONL_RELATIVE=data/index_ready/chunks/chunks.jsonl
