
function Go_Link()
{					
	var len = document.getElementById("direct_home").length;
	var str;
	for(var i=0;i<len;i++)
	{
		if(document.getElementById("direct_home")[i].selected)
		{
			str = document.getElementById("direct_home")[i].value;
		}
	}
	if(str != "stop")
	{
		window.open(str,"","");
	}
	else
	{
		alert('FAMILY SITE �������ּ���.');
		return;
	}
	return false; 
}

