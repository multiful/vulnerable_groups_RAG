//생년월일 유효성 체크//
function lfn_validate(jumin1){
	
		var yy = jumin1.substring(2,4);
		var mm = jumin1.substring(4,6);
		var dd = jumin1.substring(6,8);
		
		
		if(jumin1.length != 8 || yy < 00 || yy > 99 || mm < 01 || mm > 12 || dd < 01 || dd > 31 ){
			return false;
		}

	  return true;
}



