	$(function () {
		$('.question').each(function (idx) {
			$(this).css('cursor', 'pointer');
			$(this).click(function () {
				toggle(idx);
				 $(this).toggleClass("on");
				 $(".question").not(this).removeClass("on");
					 
			});
		});
	function toggle(i) {
		var iSpeed = 200;
		$('.answer').each(function (idx) {
			if (i == idx)
				if ($(this).is(':visible'))
					$(this).slideUp(iSpeed);
				else
					$(this).slideDown(iSpeed);
			else
				$(this).hide();
		});
	}

	});

