	function layerOpen(num) {
		$('div.divAjaxLayer').load(
		'/kor/customer/map/mappopup.jsp?num='+num+' #pop_area',
			function (data) {
				iWidth = $(this).width();
				iHeight = $(this).height();
				$.blockUI({
					message: $('div.divAjaxLayer')
					, fadeIn: 700
					, fadeOut: 700
					,css: {
						cursor:'normal',
		                width: iWidth + "px",
		                height: iHeight + "px",
		                top: '50%',
		                left: '50%',
		                margin: (-iHeight / 2) + 'px 0 0 '+ (-iWidth/2) + 'px'
					}
					, overlayCSS: { backgroundColor: '#000', opacity: 0.6 }
				});
				$('div.divAjaxLayer').unblock();
				
			}
		);
	}
	function layerClose() {
		$.unblockUI();
	}
