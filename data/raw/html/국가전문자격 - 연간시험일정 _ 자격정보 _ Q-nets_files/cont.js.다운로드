	// W3C 관련 수정 (role 속성을 data-role 속성으로 변경)
	Tab : {
		init : function() {
			$("body *").each(function(e){
				if($(this).attr("role") == "tabEl"){
					$(this).find("li").each(function(e){
						if($(this).is(":visible") == true){
							$(this).attr("role", "presentation");	
							if($(window).width() < 768){
