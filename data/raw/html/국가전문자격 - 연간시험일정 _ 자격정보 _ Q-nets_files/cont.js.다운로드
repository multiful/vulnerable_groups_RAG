			$(PopID).find(".popInner").css({
				"max-height": $(window).height() * 0.9 - $(PopID).find(".popTit").innerHeight() - bottomHeight
			});
			//console.log(bottomHeight);
			//리사이즈 팝업 높이 최대값 설정
			$(window).bind('resize load', function () {
