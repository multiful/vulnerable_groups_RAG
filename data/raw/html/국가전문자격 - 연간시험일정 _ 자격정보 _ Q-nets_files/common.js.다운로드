		//날짜 유효성 체크 dateChk(id값)
		if(!dateChk(endDt.attr("id"))){
			endDt.focus();
			return false;
		}
	}

	if(strDt&&endDt){
		if(strDt.val()>endDt.val()){
			alert("근무시작일은 종료일보다 이후로 입력할 수 없습니다.");
