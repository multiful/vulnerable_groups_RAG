	var today=new Date();
	var now_year=today.getFullYear();
	var now_month=today.getMonth()+1;
	var now_day=today.getDate();
	var now_date="";

	if(now_month<10) {
		now_month='0'+now_month;
	}
	if(now_day<10) {
		now_day='0'+now_day;
	}
	now_date=now_year+"-"+now_month+"-"+now_day;

	return now_date;
}

