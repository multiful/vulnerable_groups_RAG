/* 문자열길이체크 */
function getStrByteLength(obj) {
	var byteLength = 0;

	for (var inx = 0; inx < obj.value.length; inx++) {
		var oneChar = escape(obj.value.charAt(inx));

		if (oneChar.length == 1) {
            byteLength++;
        } else if (oneChar.indexOf("%u") != -1) {
            byteLength += 2;
        } else if (oneChar.indexOf("%") != -1) {
            byteLength += oneChar.length / 3;
        }
    }

    return byteLength;
}

