//이미지 on, off
function imgReplace(obj,flag){
	var imgSrc = obj.attr("src");
	if(flag == "on"){
		imgSrc = imgSrc.replace("_off.","_on.");
	} else if(flag == "off"){
		imgSrc = imgSrc.replace("_on.","_off.");
	}
	obj.attr("src",imgSrc);
}

