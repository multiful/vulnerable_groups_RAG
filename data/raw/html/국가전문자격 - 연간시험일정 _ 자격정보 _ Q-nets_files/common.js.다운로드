function workDayChk(idx){
	var strDt = $("input[name^=workStartDt]").eq(idx);
	var endDt = $("input[name^=workEndDt]").eq(idx);

	//var nowDt = fn_getToday();
	/*if(workDt.val()>nowDt){ 2014.08.23 배은지 과장 요청으로 날짜 체크 제거
