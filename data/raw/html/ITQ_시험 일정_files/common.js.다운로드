	/*비밀번호 패턴 체크
	 * 6~20자의 영문 대소문자와 숫자, 특수문자를 사용할 수 있으며, 최소 2종류이상을 조합
	 * 위 조건에 맞으면 true
	 * */
	function checkPwFormat(string) { 
		var pattern1 = /[0-9]/;	// 숫자 
		var pattern2 = /[a-zA-Z]/; //문자
		var pattern3 = /[\{\}\[\]\/?.|\)*~`!^\-_+\#$%\=\(]/gi;		//허용
		var pattern4 = /[<\>@\&\'"\\\;:\,]/gi;		//불허
		
	    var isValid = false;
	    var validCnt = 0;
	    
	    if(pattern1.test(string)) {
	    	validCnt++;
	    }
	    
	    if(pattern2.test(string)) {
	    	validCnt++;
	    } 
	    
	    if(pattern3.test(string)) {
	    	validCnt++;
	    }  
	    
	    if (validCnt >= 2) {
	    	isValid = true;
	    }
	    
	    if(pattern4.test(string)) {
	    	isValid = false;
	    }
	    
	    if(string.length < 6) {
	    	isValid = false;
	    }
	    return isValid; 
	}
	
