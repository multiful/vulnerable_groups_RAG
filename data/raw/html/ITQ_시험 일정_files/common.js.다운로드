	function fnMagnificPopup(arg) {
		var src = arg.attr('src');
		var imgUrls = new Array();
		var imgUrl = new Object(); 
		var selectimgNum = 0;
		arg.parent().parent().children().each(function(i) {
			imgUrl = new Object();
			imgUrl.src = $(this).children().attr("src");
			imgUrl.title = $(this).children().attr("alt");
			imgUrls.push(imgUrl);
			if (imgUrl.src == src) {
				selectimgNum = i;
			}
		});
		$.magnificPopup.open({ 
			items: imgUrls, 
			type: 'image',
			gallery: {
	      		enabled: true
	    	},
			closeOnContentClick : true, 
		}
		,selectimgNum);
	}
	
