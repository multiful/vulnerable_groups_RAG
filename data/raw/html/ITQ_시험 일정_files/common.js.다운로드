	function post_to_url(path, params, method) {
	    method = method || "post";  //defult : post
	    var form = document.createElement("form");
	    form.setAttribute("method", method);
	    form.setAttribute("action", path);
	    for(var key in params) {
	        var hiddenField = document.createElement("input");
	        hiddenField.setAttribute("type", "hidden");
	        hiddenField.setAttribute("name", key);
	        hiddenField.setAttribute("value", params[key]);
	        form.appendChild(hiddenField);
	    }
	    document.body.appendChild(form);
	    form.submit();
	}
	// 숫자 8자리인 ipinBrith를 flag에 맞게 변형 
	//flag 1 return =  '1934년 06월 07일', flag 2 return =  '1934-06-07', flag 3 return =  '1934. 06. 07'
	function parseIpinBrith(ipinBrith, flag) {
		//flag 입력 안하면 디폴트 1
		flag = flag || "1";
		if (ipinBrith.length != 8) {
			return ipinBrith;
		}
		switch (flag) {
		case '1': case '연': case '년': case '월': case '일': case '생년월일': case '한글':
			return ipinBrith.substring(0,4) + "년 " + ipinBrith.substring(4,6) + "월 " + ipinBrith.substring(6,8) + "일";
			break;
		case '2': case '-': case '하이픈': case 'hyphen':
			return ipinBrith.substring(0,4) + "-" + ipinBrith.substring(4,6) + "-" + ipinBrith.substring(6,8);
			break;
		case '3': case '.': case '점': case 'dot':
			return ipinBrith.substring(0,4) + ". " + ipinBrith.substring(4,6) + ". " + ipinBrith.substring(6,8);
			break;
		case '9': case '*': case '별':
			return "****년 " + ipinBrith.substring(4,6) + "월 " + ipinBrith.substring(6,8) + "일";
			break;
		default:
			return ipinBrith;
			break;
		}
	}
	//성별 F, M을 여자, 남자로 변경
	function parseGender(gender, flag){
		//flag 입력 안하면 디폴트 1
		flag = flag || "1";
		if (gender.length != 1) {
			return gender;
		}
		switch (flag) {
		case '1': case '남자': case '여자': case '남자여자':
			switch (gender) {
			case 'F':
				return "여자";
				break;
			case 'M':
				return "남자";
				break;
			default:
				return "기타";
				break;
			}
			break;
		case '2': case '남성': case '여성': case '남성여성':
			switch (gender) {
			case 'F':
				return "여성";
				break;
			case 'M':
				return "남성";
				break;
			default:
				return "기타";
				break;
			}
			break;
		case '3': case '남': case '녀': case '남녀':
			switch (gender) {
			case 'F':
				return "여";
				break;
			case 'M':
				return "남";
				break;
			default:
				return "-";
				break;
			}
			break;
		case '4': case 'Mail': case 'Femail': case 'MF':
			switch (gender) {
			case 'F':
				return "Female";
				break;
			case 'M':
				return "Mail";
				break;
			default:
				return "ETC";
				break;
			}
			break;
		default:
			return gender;
			break;
		}
	}
	
