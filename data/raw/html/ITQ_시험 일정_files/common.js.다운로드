	//화면을 늘린다.
	function zoomIn() {
		var checkBrowserKind = CheckBrowserKind();
		 //alert(CheckBrowserKind());
		if(checkBrowserKind == 'N' || checkBrowserKind == 'F'){
			moz+= 0.05;
		if(moz >= 1.5) moz = 1.5;
			 nZooms();
		}else if(checkBrowserKind == 'O'){
		 moz+= 0.05;
		 if(moz >= 1.5) moz = 1.5;
			oZooms();
		}else{
			nowZoom = nowZoom + 10;
		 if(nowZoom >= 200) nowZoom = 200;
			zooms();
		 }
	}
	function zoomReset(){
		nowZoom = 100; 
		moz = 1.00;
				 
		var checkBrowserKind = CheckBrowserKind();  
		if(checkBrowserKind == 'N' || checkBrowserKind == 'F')        
			nZooms();
		else if(checkBrowserKind == 'O')        
			oZooms();
		else        
			zooms();    
	}

