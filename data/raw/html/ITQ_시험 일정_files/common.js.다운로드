	 * @param tid : 바이트 체크된 값 리턴될 엘리먼트 ID
	 * @param limitLen : 제한 글자수
	 */
	function pubByteCheckTextarea(oid,tid,limitLen){
		$("#"+oid).on("keyup",function(){
			var byteTxt = "";
			var byte = function(str){
				var byteNum=0;
				for(i=0;i<str.length;i++){
					byteNum+=(str.charCodeAt(i)>127)?2:1;
					if(byteNum<limitLen*2){
						byteTxt+=str.charAt(i);
					};
				};
				return Math.round( byteNum/2 );
			};
			if(byte($(this).val())>limitLen){
				fnModalAlert(limitLen+"자 이상 입력할수 없습니다.","alert");
				$(this).val("");
				$(this).val(byteTxt);
			}else{
				$("#"+tid).html( byte($(this).val()) )
			}
		});
	};
	
