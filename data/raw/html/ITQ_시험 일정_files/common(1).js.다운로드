jQuery.fn.extend({
    /**
     * 숫자만 입력 가능하도록 처리 (최신 브라우저 및 전각 문자 완벽 대응)
     */
    numberOnly: function() {
        return this.each(function() {
            try {
                var $this = $(this);
                
                // input 이벤트: 키보드, 복사/붙여넣기, 모바일 키패드, 전각/한글 조합 등 모든 값 변경을 감지
                $this.on('input', function() {
                    var originalValue = $this.val();
                    
                    // 숫자가 아닌 모든 문자(전각 문자, 영문, 한글, 특수문자 등)를 정규식으로 제거
                    var cleanedValue = originalValue.replace(/[^0-9]/g, '');
                    
                    // 기존 값과 정제된 값이 다를 때만 덮어쓰기 (커서 깜빡임 방지)
                    if (originalValue !== cleanedValue) {
                        $this.val(cleanedValue);
                    }
                });

                // 포커스를 얻었을 때 처리 - number format을 위한 콤마 제거 (기존 로직 유지)
                $this.on('focus', function() {
                    $this.val($this.val().replace(/,/g, ''));
                });

            } catch(e) {
                console.error("[jsutil.js's numberFormat] " + e.message);
            }
        });
    }
});

