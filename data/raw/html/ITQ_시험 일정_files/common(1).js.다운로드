
/**
 * HTML 속성 ENCODE
 */
function fnEncHtmlAttr(data) {
	var rstData	= data;

	rstData	= rstData.replace(/&amp;/g,"&");
	rstData	= rstData.replace(/&gt;/g,">");
	rstData	= rstData.replace(/&lt;/g,"<");
	rstData	= rstData.replace(/&quot;/g,"\"");

	return	rstData;
}

/*
 * Object를 넘기면 object의 Property를 알려줌.
 */
function objToString (obj) {
	var str = '';
	for (var p in obj) {
		if (obj.hasOwnProperty(p)) {
			str += p + '::' + obj[p] + '\n';
		}
	}
	alert(str);
}

