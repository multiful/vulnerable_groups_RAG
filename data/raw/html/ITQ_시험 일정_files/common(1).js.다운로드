}

function applyDetailValidation (certiCode, applyDetail){
	var resultObj = {code : '0', msg : 'OK'};
	var rstCode = "00";
	var subjectCnt = applyDetail.length;
	var certiCode = certiCode;
	var arr_applyDetail = applyDetail;
	
	var subjectList = new Array();
	var swList = new Array();
	
	for (var i = 0; i < arr_applyDetail.length; i++) {
		subjectList.push(arr_applyDetail[i].subjectCode);
		swList.push(arr_applyDetail[i].swCode);
	}
	/*ITQ 일때 */
	if("ITQ" === certiCode) {
		if(subjectCnt > 1) {
			//같은과목군
			if(subjectList.contains("1111")) {
				if(subjectList.contains("1112")) rstCode = "16";
			} 

			//if(subjectList.contains("1112")) {
			//	if(subjectList.contains("1111")) rstCode = "16";
			//}
			
			if(subjectList.contains("1122")) {
				if(subjectList.contains("1121")) rstCode = "16";
			}
			
			//if(subjectList.contains("1132")) {
			//	if(subjectList.contains("1121")) rstCode = "16";
			//} 

			if(subjectList.contains("1142")) {
				if(subjectList.contains("1141")) rstCode = "16";
			}
			
			//같은 교시 배정 과목
			if(subjectList.contains("1121")) {
				if(subjectList.contains("1132")) rstCode = "16";
			} 
			
			if(subjectList.contains("1141")) {
				if(subjectList.contains("1112")) rstCode = "16";
			} 			

		}
	} else if("GTQ" === certiCode) {
		
		if(subjectCnt > 1) {
			
			//subjectSwVoList = createSubjectSwList(detailList);
			
			for(var i=0; i < arr_applyDetail.length ; i++) {
				var swCode = arr_applyDetail[i].d_sw;
				var subjectCode = arr_applyDetail[i].d_subject;
				if(subjectList.contains("GID1") && subjectList.contains("G102")) {
					if("G102" === subjectCode && "E3K" === swCode) {
						rstCode = "16";
					}
				} 
				if(subjectList.contains("GID2") && subjectList.contains("G103")) {
					if("G103" === subjectCode && "E3K"=== swCode) {
						rstCode = "16";
					}
				} 
				if(subjectList.contains("GID3") && subjectList.contains("G103")) {
					if("G103" === subjectCode && "E3K" === swCode) {
						rstCode = "16";
					}
				}
				if(subjectList.contains("GID2") && subjectList.contains("GID3")) {
					rstCode = "16";
				}
				if(subjectList.contains("G103") && subjectList.contains("GID2")) {
					rstCode = "16";
				}
				//3급 끼리 접수 불가
				if((subjectList.contains("G103") && subjectList.contains("GID3"))
						|| (subjectList.contains("G103") && subjectList.contains("GL03"))
						|| (subjectList.contains("GID3") && subjectList.contains("GL03"))
						) {
							rstCode = "16";
				}
			}
			
		}
		
	} else if("ERP"===certiCode) {
		if(subjectCnt > 1) {
			if(subjectList.contains("E11")) {
				
				if(subjectList.contains("E21") || subjectList.contains("E13") || subjectList.contains("E23")) rstCode = "16";
				
			} else if(subjectList.contains("E21")) {
				
				if(subjectList.contains("E11") || subjectList.contains("E13") || subjectList.contains("E23")) rstCode = "16";
				
			} else if(subjectList.contains("E13")) {
				
				if(subjectList.contains("E11") || subjectList.contains("E21") || subjectList.contains("E23")) rstCode = "16";
				
			} else if(subjectList.contains("E23")) {
				
				if(subjectList.contains("E11") || subjectList.contains("E21") || subjectList.contains("E13")) rstCode = "16";
				
			} else if(subjectList.contains("E12")) {
				
				if(subjectList.contains("E22") || subjectList.contains("E14") || subjectList.contains("E24")) rstCode = "16";
				
			} else if(subjectList.contains("E22")) {
				
				if(subjectList.contains("E12") || subjectList.contains("E14") || subjectList.contains("E24")) rstCode = "16";
				
			} else if(subjectList.contains("E14")) {
				
				if(subjectList.contains("E12") || subjectList.contains("E22") || subjectList.contains("E24")) rstCode = "16";
				
			} else if(subjectList.contains("E24")) {
				
				if(subjectList.contains("E12") || subjectList.contains("E22") || subjectList.contains("E14")) rstCode = "16";
				
			}
		}
	}

	if(rstCode === "16") {
		resultObj.code = "1";
		resultObj.msg = "FAIL";
	}

	//console.log("resultObj.code",resultObj.code);
	//console.log("resultObj.msg",resultObj.msg);

	return resultObj;
}

